generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(cuid()) @db.VarChar(64)
  username          String        @unique @db.VarChar(64)
  email             String?       @unique @db.VarChar(191)
  passwordHash      String?       @db.VarChar(191)
  nickname          String        @db.VarChar(80)
  avatarUrl         String        @db.VarChar(512)
  avatarPosition    String?       @db.VarChar(64)
  coverUrl          String        @db.VarChar(512)
  bio               String        @db.Text
  level             Int           @default(1)
  creatorBadge      String?       @db.VarChar(80)
  favoriteCharacter String        @db.Text
  stats             String        @db.Text
  role              String        @default("user") @db.VarChar(24)
  status            String        @default("active") @db.VarChar(24)
  isFollowing       Boolean       @default(false)
  theme             String        @default("sakura") @db.VarChar(32)
  posts             Post[]
  comments          Comment[]
  animeRecords      AnimeRecord[]
  draft             Draft?
  draftSnapshots    DraftSnapshot[]
  reports           Report[]      @relation("Reporter")
  createdAt         DateTime      @default(now()) @db.DateTime(3)
  updatedAt         DateTime      @updatedAt @db.DateTime(3)
}

model Post {
  id            String    @id @default(cuid()) @db.VarChar(64)
  authorId      String    @db.VarChar(64)
  title         String    @db.VarChar(191)
  excerpt       String    @db.Text
  content       String    @db.LongText
  coverUrl      String    @db.VarChar(512)
  imagePosition String?   @db.VarChar(64)
  type          String    @db.VarChar(24)
  tags          String    @db.Text
  series        String?   @db.VarChar(120)
  gallery       String    @db.Text
  viewCount     Int       @default(0)
  likeCount     Int       @default(0)
  favoriteCount Int       @default(0)
  commentCount  Int       @default(0)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  status        String    @default("published") @db.VarChar(24)
  isPinned      Boolean   @default(false)
  isLiked       Boolean   @default(false)
  isFavorited   Boolean   @default(false)
  reactions     String    @db.Text
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  reports       Report[]

  @@index([authorId])
  @@index([status, createdAt])
  @@index([isPinned, createdAt])
}

model Comment {
  id        String   @id @default(cuid()) @db.VarChar(64)
  postId    String   @db.VarChar(64)
  userId    String   @db.VarChar(64)
  parentId  String?  @db.VarChar(64)
  content   String   @db.Text
  likeCount Int      @default(0)
  createdAt DateTime @default(now()) @db.DateTime(3)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentId])
}

model AnimeRecord {
  id        String   @id @default(cuid()) @db.VarChar(64)
  userId    String   @db.VarChar(64)
  title     String   @db.VarChar(191)
  coverUrl  String   @db.VarChar(512)
  status    String   @db.VarChar(32)
  rating    Int
  review    String   @db.Text
  updatedAt DateTime @updatedAt @db.DateTime(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([status])
}

model Draft {
  id      String    @id @default(cuid()) @db.VarChar(64)
  userId  String    @unique @db.VarChar(64)
  title   String    @db.VarChar(191)
  content String    @db.LongText
  tags    String    @db.Text
  images  String    @db.Text
  savedAt DateTime? @db.DateTime(3)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DraftSnapshot {
  id        String   @id @default(cuid()) @db.VarChar(64)
  userId    String   @db.VarChar(64)
  title     String   @db.VarChar(191)
  content   String   @db.LongText
  tags      String   @db.Text
  images    String   @db.Text
  createdAt DateTime @default(now()) @db.DateTime(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Report {
  id         String   @id @default(cuid()) @db.VarChar(64)
  postId     String   @db.VarChar(64)
  reporterId String   @db.VarChar(64)
  reason     String   @db.VarChar(80)
  detail     String?  @db.Text
  status     String   @default("open") @db.VarChar(24)
  createdAt  DateTime @default(now()) @db.DateTime(3)
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([reporterId])
  @@index([status, createdAt])
}

model SiteSetting {
  key       String   @id @db.VarChar(80)
  value     String   @db.LongText
  updatedAt DateTime @updatedAt @db.DateTime(3)
}
